# Backend Environment Variables
# Copy this to .env and fill in your actual values

# ============== SERVER ==============
NODE_ENV=production
PORT=5000

# ============== DATABASE ==============
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/property-management
DB_NAME=property_management

# ============== JWT ==============
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret

# ============== FRONTEND ==============
FRONTEND_URL=http://localhost:5173
FRONTEND_PRODUCTION_URL=https://yourdomain.com

# ============== PAYMENT PROCESSORS ==============

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret

# Razorpay Configuration
RAZORPAY_API_KEY=your_razorpay_api_key
RAZORPAY_API_SECRET=your_razorpay_api_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ============== EMAIL ==============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourapp.com

# ============== NOTIFICATIONS ==============
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ============== AWS (Optional for file uploads) ==============
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_BUCKET=your-bucket-name

# ============== ANALYTICS (Optional) ==============
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
MIXPANEL_TOKEN=your_mixpanel_token

# ============== CRON JOBS ==============
ENABLE_CRON_JOBS=true
CRON_INVOICE_GENERATION=0 0 5 * * * # 5 AM daily
CRON_OVERDUE_NOTIFICATIONS=0 0 6 * * * # 6 AM daily

# ============== LOGGING ==============
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ============== SECURITY ==============
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============== API KEYS ==============
API_RATE_LIMIT_ENABLED=true
API_KEY_REQUIRED=false
